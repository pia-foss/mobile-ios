#!/bin/bash

echo "Running swift-format on staged Swift files..."

# Get list of staged .swift files
FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$')

if [ -z "$FILES" ]; then
    exit 0
fi

# Initialize an array to hold modified files
MODIFIED_FILES=()

for FILE in $FILES; do
    if [ -f "$FILE" ]; then
        SHA_BEFORE=$(git hash-object "$FILE")
        swift format -i "$FILE"
        SHA_AFTER=$(git hash-object "$FILE")

        if [ "$SHA_BEFORE" != "$SHA_AFTER" ]; then
            MODIFIED_FILES+=("$FILE")
        fi
    fi
done

if [ ${#MODIFIED_FILES[@]} -gt 0 ]; then
    echo ""
    echo "swift-format modified the following files:"
    for FILE in "${MODIFIED_FILES[@]}"; do
        echo "  - $FILE"
    done
    echo ""
    echo "Please review the changes, stage them (git add), and commit again."
    exit 1
else
    echo "All staged Swift files are properly formatted."
fi
